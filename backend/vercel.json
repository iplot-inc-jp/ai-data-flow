{
  "rewrites": [{ "source": "/(.*)", "destination": "/api/index" }],
  "functions": {
    "api/index.js": {
      "includeFiles": "{dist/**,node_modules/swagger-ui-dist/**}",
      "maxDuration": 30
    }
  },
  "buildCommand": "npx prisma generate && npx prisma db push && npx nest build",
  "installCommand": "npm install"
}
